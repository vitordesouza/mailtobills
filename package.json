{
  "name": "mailtobills",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --filter @mailtobills/domain build && turbo dev",
    "lint": "turbo lint",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:dashboard": "playwright test --config playwright.dashboard.config.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@mailtobills/eslint-config": "workspace:*",
    "@mailtobills/typescript-config": "workspace:*",
    "@playwright/test": "^1.57.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10",
      "picomatch": "2.3.2",
      "flatted": "3.4.2",
      "ajv@<7": "6.14.0",
      "minimatch@<4": "3.1.4",
      "brace-expansion@<2": "1.1.13"
    }
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20"
  }
}
